# SQLite (local dev only — NOT for 150 concurrent users)
DATABASE_URL="file:./dev.db"

# PostgreSQL (REQUIRED for production / 150 users)
# DATABASE_URL="postgresql://quizzer:quizzer123@localhost:5432/quizzer?schema=public&connection_limit=25&pool_timeout=20"

JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development

FRONTEND_URL="http://localhost:3000"
FRONTEND_URLS="http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001"

ADMIN_EMAILS="admin@quizzer.dev,your.email@company.com"

# Performance (150 concurrent quiz takers)
WEB_CONCURRENCY=4
MAX_CONNECTIONS=512
RATE_LIMIT_MAX=400
AUTH_RATE_LIMIT_MAX=40
PROGRESS_SAVE_MS=4000
LEADERBOARD_CACHE_MS=5000

# Codeforces API Integration (Optional but required for Gyms)
CODEFORCES_API_KEY=""
CODEFORCES_API_SECRET=""
