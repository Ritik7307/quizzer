generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  name               String
  role               Role               @default(CANDIDATE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  avatarUrl          String?
  recoveryAnswerHash String?
  recoveryQuestion   String?
  codeforcesHandle   String?
  leetcodeHandle     String?
  lastSolvedDate     DateTime?
  points             Int                @default(0)
  streak             Int                @default(0)
  lastActiveAt       DateTime           @default(now())
  attempts            Attempt[]
  codingSubmissions   CodingSubmission[]
  compilerNotes       CompilerNote[]
  feedbacks           Feedback[]
  notifications       Notification[]
  quizzes             Quiz[]              @relation("QuizCreator")
  followers           Follows[]           @relation("UserFollowers")
  following           Follows[]           @relation("UserFollowing")
  userBadges          UserBadge[]
  matchParticipations MatchParticipant[]
  questionComments    QuestionComment[]

  @@index([role])
}

model Quiz {
  id           String     @id @default(cuid())
  title        String
  description  String     @default("")
  instructions String     @default("")
  duration     Int
  published    Boolean    @default(false)
  startTime    DateTime?
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdById  String
  attempts     Attempt[]
  questions    Question[]
  createdBy    User       @relation("QuizCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([published])
  @@index([startTime, endTime])
}

model Question {
  id                 String   @id @default(cuid())
  quizId             String
  text               String
  options            String
  type               String   @default("SINGLE_CHOICE")
  correctOptionIndex Int      @default(0)
  correctAnswers     String?
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  quiz               Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model Attempt {
  id             String    @id @default(cuid())
  userId         String
  quizId         String
  answers        String    @default("{}")
  score          Int       @default(0)
  percentage     Float     @default(0)
  correctCount   Int       @default(0)
  wrongCount     Int       @default(0)
  totalQuestions Int       @default(0)
  rank           Int?
  startedAt      DateTime  @default(now())
  submittedAt    DateTime?
  expiresAt      DateTime?
  quiz           Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback       Feedback?

  @@unique([userId, quizId])
  @@index([quizId])
  @@index([submittedAt])
  @@index([quizId, submittedAt])
  @@index([quizId, score])
  @@index([quizId, rank])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CodingQuestion {
  id              String             @id @default(cuid())
  title           String
  description     String
  inputFormat     String             @default("")
  outputFormat    String             @default("")
  sampleInput     String             @default("")
  sampleOutput    String             @default("")
  testCases       String             @default("[]")
  difficulty      String             @default("Easy")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  editorial       String?
  referenceUrl    String?
  constraints     String             @default("")
  topic           String             @default("General")
  isExternalOnly  Boolean            @default(false)
  submissions     CodingSubmission[]
  dailyChallenges DailyChallenge[]
  matches         Match[]
  comments        QuestionComment[]
}

model CodingSubmission {
  id               String         @id @default(cuid())
  userId           String
  codingQuestionId String
  code             String
  language         String
  status           String
  passedCount      Int
  totalCount       Int
  errorDetails     String?
  createdAt        DateTime       @default(now())
  codingQuestion   CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([codingQuestionId])
}

model Feedback {
  id            String   @id @default(cuid())
  attemptId     String?  @unique
  rating        Int
  difficulty    String   @default("Medium")
  comments      String?
  createdAt     DateTime @default(now())
  category      String   @default("General")
  userId        String?
  adminResponse String?
  attempt       Attempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompilerNote {
  id        String   @id @default(cuid())
  userId    String
  title     String
  code      String?
  language  String?
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  fileData    String?
}

model DailyChallenge {
  id               String         @id @default(cuid())
  date             DateTime       @unique
  codingQuestionId String
  createdAt        DateTime       @default(now())
  codingQuestion   CodingQuestion @relation(fields: [codingQuestionId], references: [id])
}

model Follows {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Match {
  id               String             @id @default(cuid())
  codingQuestionId String
  status           String             @default("IN_PROGRESS")
  startTime        DateTime           @default(now())
  endTime          DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  codingQuestion   CodingQuestion     @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)
  participants     MatchParticipant[]

  @@index([status])
  @@index([codingQuestionId])
}

model MatchParticipant {
  matchId  String
  userId   String
  status   String   @default("JOINED")
  score    Int      @default(0)
  winner   Boolean  @default(false)
  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([matchId, userId])
  @@index([userId])
}

model QuestionComment {
  id               String         @id @default(cuid())
  userId           String
  codingQuestionId String
  content          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  codingQuestion   CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)

  @@index([codingQuestionId])
  @@index([userId])
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String      @default("")
  icon        String      @default("🏅")
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]
}

model UserBadge {
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
}

enum Role {
  ADMIN
  CANDIDATE
}
